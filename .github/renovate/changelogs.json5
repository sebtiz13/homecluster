{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Victoria metrics operator source url",
      matchPackageNames: ["victoriametrics/operator"],
      sourceUrl: "https://github.com/VictoriaMetrics/operator",
    },
    {
      description: "SeaweedFS source url",
      matchPackageNames: ["seaweedfs"],
      sourceUrl: "https://github.com/seaweedfs/seaweedfs",
      changelogUrl: "https://github.com/seaweedfs/seaweedfs/releases",
    },
  ],
}
