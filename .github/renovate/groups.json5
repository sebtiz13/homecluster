{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: ["Separate PRs for github"],
      matchFileNames: ["**/.github/**"],
      groupName: "github",
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: ["Separate PRs for ansible"],
      matchFileNames: ["**/ansible/**"],
      groupName: "ansible",
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: ["Kubernetes Group"],
      matchDatasources: ["pypi", "github-releases", "docker", "github-tags"],
      matchDepNames: [
        "kubernetes",
        "kubernetes-validate",
        "k3s-io/k3s",
        "alpine/k8s",
        "kubernetes/kubernetes",
        "kubectl",
      ],
      groupName: "kubernetes",
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      separateMajorMinor: false,
      separateMinorPatch: true,
    },
    {
      description: ["Flux Group"],
      matchDepNames: ["fluxcd/flux2", "ghcr.io/fluxcd/*-controller", "flux2"],
      groupName: "flux",
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      separateMinorPatch: true,
    },
  ],
}
