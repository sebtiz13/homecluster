{
  "ansible.python.interpreterPath": "${workspaceFolder}/ansible/.venv/bin/python",
  "ansible.python.activationScript": "./ansible/.venv/bin/activate",
  "files.associations": {
    "*.yaml.j2": "yaml",
    "*.conf.j2": "properties",
    "*.json.j2": "json",
    "*.xml.j2": "xml",
    "**/ansible/{site,salamandre,baku}.yaml": "ansible",
    "**/ansible/**/{handlers,tasks}/**/*.yaml": "ansible",
    ".mise/tasks/**/*": "shellscript"
  },
  "[yaml]": {
    "editor.formatOnSave": false
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "yaml.schemaStore.enable": true,
  "yaml.schemas": {
    "kubernetes": "./kubernetes/**/*.yaml"
  }
}
