#!/usr/bin/env bash
#MISE description="Start virtual machines"
#USAGE flag "--host <host>" help="Limit to only specified machine" {
#USAGE   choices "salamandre" "baku"
#USAGE   default ""
#USAGE }

set -euo pipefail
# shellcheck disable=SC1091
source "$(dirname "$0")/../_lib.sh"

NETWORK="sebtiz13"
HOST_ARG=${usage_host:-}
HOSTS=(salamandre baku)
if [[ -n "$HOST_ARG" ]]; then
  HOSTS=("$HOST_ARG")
fi

# Start libvirt
echo "Ensure libvirt is running"
systemctl is-active --quiet libvirtd || sudo systemctl start libvirtd
systemctl is-active --quiet virtlogd || sudo systemctl start virtlogd

start_network() {
  local net="$1"
  local state

  state="$(virsh net-info --network "$net" 2>/dev/null | awk -F': *' '/^Active:/ {print $2}')"
  if [[ "$state" == "yes" ]]; then
    echo "Network $net already active"
  else
    echo "Starting network $net..."
    virsh net-start --network "$net"
  fi
}

start_vm() {
  local vm="$1"
  local state

  state="$(virsh domstate "$vm" 2>/dev/null | tr -d '\r' | xargs)"
  case "$state" in
    running)
      echo "VM $vm already running"
    ;;
    "shut off")
      echo "Starting VM $vm..."
      virsh start "$vm"
    ;;
    paused)
      echo "Resuming VM $vm..."
      virsh resume "$vm"
      ;;
    pmsuspended)
      echo "Waking up VM $vm..."
      virsh dompmwakeup "$vm"
    ;;
    "in shutdown")
      echo "VM $vm is shutting down, not starting it now" >&2
    ;;
    *)
      echo "VM $vm in unexpected state: $state" >&2
    ;;
  esac
}

# Start network
start_network "$NETWORK"

# Start machine
for host in "${HOSTS[@]}"; do
  start_vm "$host"
done
