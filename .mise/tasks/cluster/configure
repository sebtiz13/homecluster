#!/usr/bin/env bash
#MISE description="Configure cluster applications"
#MISE alias="reconfigure"
#MISE depends=["init"]
#USAGE flag "--host <host>" help="Limit to only specified machine" {
#USAGE   choices "salamandre" "baku"
#USAGE   default ""
#USAGE }
#USAGE arg "<environment>" env="ENVIRONMENT" help="Targeted environment" {
#USAGE   choices "dev" "production"
#USAGE }
#USAGE arg "[domain]" env="DOMAIN_NAME" help="Domain name"

set -euo pipefail
# shellcheck disable=SC1091
source "$(dirname "$0")/../_lib.sh"

# Validate and parse arguments
ENVIRONMENT="${usage_environment?}"
DOMAIN_NAME="${usage_domain:-}"

validate_args "$ENVIRONMENT" "$DOMAIN_NAME"
DOMAIN_NAME=$(resolve_domain "$ENVIRONMENT" "$DOMAIN_NAME")

run_ansible k3s_configure "$ENVIRONMENT" "$DOMAIN_NAME" "$(limit_flag "${usage_host?}")"
