#!/usr/bin/env bash
# shellcheck disable=SC2086
#MISE description="Deploy the cluster (all-in-one command)"
#MISE depends=["init"]
#USAGE flag "--host <host>" help="Limit to only specified machine" {
#USAGE   choices "salamandre" "baku"
#USAGE   default ""
#USAGE }
#USAGE arg "<environment>" env="ENVIRONMENT" help="Deployment environment" {
#USAGE   choices "dev" "production"
#USAGE }
#USAGE arg "[domain]" env="DOMAIN_NAME" help="Domain name"

set -euo pipefail
# shellcheck disable=SC1091
source "$(dirname "$0")/../_lib.sh"

# Validate and parse arguments
ENVIRONMENT="${usage_environment?}"
DOMAIN="${usage_domain:-}"
HOST_FLAG=${usage_host:+--host "$usage_host"}

validate_args "$ENVIRONMENT" "$DOMAIN"
DOMAIN=$(resolve_domain "$ENVIRONMENT" "$DOMAIN")

# Run sub commands
mise run credentials:generate "$ENVIRONMENT"

if [ "$ENVIRONMENT" = "dev" ]; then
  mise run vm:create $HOST_FLAG
  echo "Waiting VMs start..."
  sleep 20
fi

mise run node:setup "$ENVIRONMENT" "$DOMAIN" $HOST_FLAG
mise run cluster:bootstrap "$ENVIRONMENT" "$DOMAIN" $HOST_FLAG
mise run cluster:configure "$ENVIRONMENT" "$DOMAIN" $HOST_FLAG
